{
  "productName": "Conjure3D",
  "version": "0.0.1",
  "identifier": "com.conjure3d.desktop",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "pnpm dev",
    "beforeBuildCommand": "pnpm build"
  },
  "app": {
    "withGlobalTauri": false,
    "windows": [
      {
        "title": "Conjure3D",
        "width": 1280,
        "height": 800,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null,
      "assetProtocol": {
        "enable": true,
        "scope": ["**"]
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": "nsis",
    "createUpdaterArtifacts": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": {
      "resources/sidecar.exe": "sidecar.exe",
      "resources/blender_mcp_addon.zip": "blender_mcp_addon.zip"
    },
    "windows": {
      "certificateThumbprint": null,
      "digestAlgorithm": "sha256",
      "timestampUrl": "http://timestamp.digicert.com"
    }
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://github.com/Smurphy888/conjure3d-releases/releases/latest/download/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IENBRkZERTgzOUFCMEYxQTYKUldTbThiQ2FnOTcveW9KdE9VaHB5ZnNiQlN5QWdDRDhicXg1Ti9ZN29SNFVldWtpOHR5T2ttNEwK",
      "windows": {
        "installMode": "passive"
      }
    }
  }
}
